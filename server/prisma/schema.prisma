generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Usuários da plataforma
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notebooks      Notebook[]
  studySessions  StudySession[]
  tags           Tag[]
  bookmarks      Bookmark[]
  editHistory    EditHistory[]
  todos          Todo[]
  events         Event[]
  goals          Goal[]
  pomodoroSessions PomodoroSession[]
  questions        Question[]
  mockExams        MockExam[]
}

/// Cadernos de anotação (disciplinas/matérias)
model Notebook {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  color       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft-delete: nulo = ativo, preenchido = na lixeira

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves         Leaf[]
  flashcards     Flashcard[]
  studySessions  StudySession[]
  bookmarks      Bookmark[]
  editHistory    EditHistory[]
  questions      Question[]
  mockExams      MockExam[]
}

/// Folhas de anotação (aulas individuais dentro de um caderno)
model Leaf {
  id         String    @id @default(uuid())
  notebookId String
  title      String
  content    String    @default("")
  rawText    String    @default("")
  summary    String?
  parentId   String?   // Para sub-folhas (árvore hierárquica)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  position   Int       @default(0)   // Ordenação manual (drag & drop)
  archivedAt DateTime? // Arquivado: nulo = ativo, preenchido = arquivado
  deletedAt  DateTime? // Soft-delete: nulo = ativo, preenchido = na lixeira

  notebook   Notebook     @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  parent     Leaf?        @relation("LeafChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   Leaf[]       @relation("LeafChildren")
  tags       LeafTag[]
  bookmarks  Bookmark[]
  editHistory EditHistory[]
  questions  Question[]
}

/// Histórico de edições de folhas e cadernos
model EditHistory {
  id         String   @id @default(uuid())
  userId     String
  leafId     String?
  notebookId String?
  action     String   // "created", "updated", "deleted", "restored"
  fieldName  String?  // "title", "content", "summary", etc.
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaf     Leaf?     @relation(fields: [leafId], references: [id], onDelete: Cascade)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

/// Tags para classificação de folhas
model Tag {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("#aa3bff")
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves LeafTag[]

  @@unique([userId, name])
}

/// Relação N:N entre Leaf e Tag
model LeafTag {
  leafId String
  tagId  String

  leaf Leaf @relation(fields: [leafId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leafId, tagId])
}

/// Marcadores de páginas (bookmarks)
model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  leafId    String?
  notebookId String?
  title     String
  path      String
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaf     Leaf?    @relation(fields: [leafId], references: [id], onDelete: SetNull)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
}

/// Questões de estudo (múltipla escolha, verdadeiro/falso, resposta curta)
model Question {
  id             String   @id @default(uuid())
  leafId         String?
  notebookId     String
  userId         String
  question       String
  options        String   @default("[]") // JSON array de opções
  correctAnswer  String
  explanation    String?
  questionType   String   @default("multiple_choice") // "multiple_choice" | "true_false" | "short_answer"
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  notebook      Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  leaf          Leaf?    @relation(fields: [leafId], references: [id], onDelete: SetNull)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  examQuestions MockExamQuestion[]
}

/// Simulados (agrupamentos de questões)
model MockExam {
  id          String   @id @default(uuid())
  userId      String
  notebookId  String?
  title       String
  description String?
  timeLimit   Int?     // em minutos
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  notebook  Notebook?         @relation(fields: [notebookId], references: [id], onDelete: SetNull)
  questions MockExamQuestion[]
}

/// Relação N:N entre MockExam e Question
model MockExamQuestion {
  id         String   @id @default(uuid())
  examId     String
  questionId String
  order      Int      @default(0)

  exam     MockExam @relation(fields: [examId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@unique([examId, questionId])
}

/// Flashcards gerados por IA com parâmetros do algoritmo SM-2
model Flashcard {
  id             String   @id @default(uuid())
  leafId         String
  notebookId     String
  front          String
  back           String
  repetitions    Int      @default(0)
  interval       Int      @default(0)
  easeFactor     Float    @default(2.5)
  nextReviewDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leaf     Leaf     @relation(fields: [leafId], references: [id], onDelete: Cascade)
  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

/// Tarefas da lista de afazeres (todo-list)
/// Eventos de agenda e cronograma (planejamento)
model Event {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  date        DateTime
  time        String?     // "HH:mm"
  type        String      @default("agenda") // "agenda" | "cronograma"
  status      String      @default("pending") // "pending" | "completed" | "cancelled"
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Metas de estudo (planejamento)
model Goal {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  targetDate  DateTime?
  progress    Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Sessões de Pomodoro
model PomodoroSession {
  id         String    @id @default(uuid())
  userId     String
  taskName   String?
  duration   Int       @default(25)
  completed  Boolean   @default(false)
  startedAt  DateTime?
  endedAt    DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Todo {
  id         String   @id @default(uuid())
  userId     String
  title      String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Sessões de estudo persistentes (progresso do usuário)
model StudySession {
  id               String   @id @default(uuid())
  notebookId       String
  userId           String
  currentIndex     Int      @default(0)
  reviewedCount    Int      @default(0)
  showAnswer       Boolean  @default(false)
  sessionActive    Boolean  @default(false)
  flashcards       String   @default("[]")
  completedCardIds String   @default("[]")
  scores           String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notebookId, userId])
}
