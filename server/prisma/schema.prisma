generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Usuários da plataforma
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notebooks      Notebook[]
  studySessions  StudySession[]
}

/// Cadernos de anotação (disciplinas/matérias)
model Notebook {
  id          String   @id @default(uuid())
  userId      String
  title       String
  description String?
  color       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves         Leaf[]
  flashcards     Flashcard[]
  studySessions  StudySession[]
}

/// Folhas de anotação (aulas individuais dentro de um caderno)
model Leaf {
  id         String   @id @default(uuid())
  notebookId String
  title      String
  content    String   @default("")
  rawText    String   @default("")
  summary    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  notebook   Notebook     @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
}

/// Flashcards gerados por IA com parâmetros do algoritmo SM-2
model Flashcard {
  id             String   @id @default(uuid())
  leafId         String
  notebookId     String
  front          String
  back           String
  repetitions    Int      @default(0)
  interval       Int      @default(0)
  easeFactor     Float    @default(2.5)
  nextReviewDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leaf     Leaf     @relation(fields: [leafId], references: [id], onDelete: Cascade)
  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

/// Sessões de estudo persistentes (progresso do usuário)
model StudySession {
  id               String   @id @default(uuid())
  notebookId       String
  userId           String
  currentIndex     Int      @default(0)
  reviewedCount    Int      @default(0)
  showAnswer       Boolean  @default(false)
  sessionActive    Boolean  @default(false)
  flashcards       String   @default("[]")
  completedCardIds String   @default("[]")
  scores           String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notebookId, userId])
}
