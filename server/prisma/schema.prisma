generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

/// Usuários da plataforma
model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  avatarUrl String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notebooks      Notebook[]
  studySessions  StudySession[]
  tags           Tag[]
  bookmarks      Bookmark[]
  editHistory    EditHistory[]
  todos          Todo[]
}

/// Cadernos de anotação (disciplinas/matérias)
model Notebook {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  color       String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft-delete: nulo = ativo, preenchido = na lixeira

  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves         Leaf[]
  flashcards     Flashcard[]
  studySessions  StudySession[]
  bookmarks      Bookmark[]
  editHistory    EditHistory[]
}

/// Folhas de anotação (aulas individuais dentro de um caderno)
model Leaf {
  id         String    @id @default(uuid())
  notebookId String
  title      String
  content    String    @default("")
  rawText    String    @default("")
  summary    String?
  parentId   String?   // Para sub-folhas (árvore hierárquica)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  position   Int       @default(0)   // Ordenação manual (drag & drop)
  archivedAt DateTime? // Arquivado: nulo = ativo, preenchido = arquivado
  deletedAt  DateTime? // Soft-delete: nulo = ativo, preenchido = na lixeira

  notebook   Notebook     @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  flashcards Flashcard[]
  parent     Leaf?        @relation("LeafChildren", fields: [parentId], references: [id], onDelete: SetNull)
  children   Leaf[]       @relation("LeafChildren")
  tags       LeafTag[]
  bookmarks  Bookmark[]
  editHistory EditHistory[]
}

/// Histórico de edições de folhas e cadernos
model EditHistory {
  id         String   @id @default(uuid())
  userId     String
  leafId     String?
  notebookId String?
  action     String   // "created", "updated", "deleted", "restored"
  fieldName  String?  // "title", "content", "summary", etc.
  oldValue   String?
  newValue   String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaf     Leaf?     @relation(fields: [leafId], references: [id], onDelete: Cascade)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

/// Tags para classificação de folhas
model Tag {
  id        String   @id @default(uuid())
  userId    String
  name      String
  color     String   @default("#aa3bff")
  createdAt DateTime @default(now())

  user   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaves LeafTag[]

  @@unique([userId, name])
}

/// Relação N:N entre Leaf e Tag
model LeafTag {
  leafId String
  tagId  String

  leaf Leaf @relation(fields: [leafId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([leafId, tagId])
}

/// Marcadores de páginas (bookmarks)
model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  leafId    String?
  notebookId String?
  title     String
  path      String
  createdAt DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  leaf     Leaf?    @relation(fields: [leafId], references: [id], onDelete: SetNull)
  notebook Notebook? @relation(fields: [notebookId], references: [id], onDelete: SetNull)
}

/// Flashcards gerados por IA com parâmetros do algoritmo SM-2
model Flashcard {
  id             String   @id @default(uuid())
  leafId         String
  notebookId     String
  front          String
  back           String
  repetitions    Int      @default(0)
  interval       Int      @default(0)
  easeFactor     Float    @default(2.5)
  nextReviewDate DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  leaf     Leaf     @relation(fields: [leafId], references: [id], onDelete: Cascade)
  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
}

/// Tarefas da lista de afazeres (todo-list)
model Todo {
  id         String   @id @default(uuid())
  userId     String
  title      String
  completed  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

/// Sessões de estudo persistentes (progresso do usuário)
model StudySession {
  id               String   @id @default(uuid())
  notebookId       String
  userId           String
  currentIndex     Int      @default(0)
  reviewedCount    Int      @default(0)
  showAnswer       Boolean  @default(false)
  sessionActive    Boolean  @default(false)
  flashcards       String   @default("[]")
  completedCardIds String   @default("[]")
  scores           String   @default("{}")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  notebook Notebook @relation(fields: [notebookId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([notebookId, userId])
}
