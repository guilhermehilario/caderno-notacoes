# ============================================
# Configuração do Servidor Revisa Aula
# ============================================

# Porta onde o servidor será executado
PORT=3000

# Chave secreta para assinar tokens JWT de acesso
# AVISO: Nunca compartilhe ou commite esta chave!
JWT_SECRET=super-secret-key-revisa-aula

# Chave secreta para assinar tokens de refresh
# AVISO: Nunca compartilhe ou commite esta chave!
REFRESH_SECRET=super-secret-refresh-key-revisa-aula

# Ambiente: 'development' | 'production'
NODE_ENV=development
